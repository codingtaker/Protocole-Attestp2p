# === AttestP2P — configuration d'exemple ===
# Copier ce fichier en .env et renseigner les valeurs. Ne jamais committer .env.

# Clé partagée pour le HMAC-SHA256 (obligatoire — le noeud refuse de démarrer sans).
# Générer une valeur forte, ex : openssl rand -hex 32
HMAC_SECRET=change-me-openssl-rand-hex-32

# Port d'écoute TCP (défaut : 7777)
TCP_PORT=7777

# Nom lisible du noeud, diffusé dans les annonces discovery (défaut : attestp2p-node)
NODE_NAME=attestp2p-node

# Fichier de persistance de l'identité Ed25519 (seed). Ignoré par git (*.key).
# Défaut : ./identity.key
IDENTITY_FILE=identity.key

# Discovery UDP multicast (défauts ci-dessous)
MULTICAST_ADDR=239.255.42.99
MULTICAST_PORT=6000
