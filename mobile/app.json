{
  "expo": {
    "name": "AttestP2P",
    "slug": "attestp2p",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "attestp2p",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1720"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.attestp2p.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1720"
      }
    },
    "ios": {
      "bundleIdentifier": "com.attestp2p.app",
      "supportsTablet": true
    },
    "web": {
      "favicon": "./assets/icon.png",
      "bundler": "metro"
    }
  }
}
